{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": ["bunx", "@playwright/mcp@latest", "--browser", "webkit"]
    },
    "context7": {
      "enabled": true,
      "type": "local",
      "command": ["bunx", "@upstash/context7-mcp"]
    },
    "github": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer <TOKEN>"
      }
    }
  },
  "permission": {
    "webfetch": "allow",
    "bash": {
      "git status": "allow",
      "git diff": "allow",
      "npm run build": "allow",
      "ls": "allow",
      "pwd": "allow",
      "kubectl get secrets": "deny",
      "kubectl get secret": "deny",
      "kubectl get *": "allow",
      "rg *": "allow",
      "rm -rf *": "ask",
      "rm *": "ask"
    }
  },
  "agent": {
    "pair": {
      "description": "AI pair programmer that keeps you in the loop by asking for your confirmation before executing any commands and edits",
      "permission": {
        "webfetch": "allow",
        "edit": "ask",
        "bash": {
          "*": "ask",
          "bun run *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "git status": "allow",
          "kubectl get *": "allow",
          "kubectl get secret": "deny",
          "kubectl get secrets": "deny",
          "ls": "allow",
          "mix *": "allow",
          "npm run *": "allow",
          "pnpm run *": "allow",
          "pwd": "allow",
          "rg *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "task *": "allow"
        }
      }
    }
  },
  "experimental": {}
}
