[
  {
    "plugin_id": "dotfiles.command-palette",
    "name": "Command Palette",
    "version": "0.1.0",
    "min_herdr_version": "0.7.4",
    "description": "Dotfiles Herdr command palette",
    "manifest_path": "/Users/Dorian.Karter/dotfiles/config/herdr/plugins/command-palette/herdr-plugin.toml",
    "plugin_root": "/Users/Dorian.Karter/dotfiles/config/herdr/plugins/command-palette",
    "enabled": true,
    "platforms": ["macos", "linux"],
    "actions": [
      {
        "id": "delete-current-worktree",
        "title": "Delete current worktree",
