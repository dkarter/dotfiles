{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "incremental": true,
  "lineWidth": 120,
  "biome": {
    "indentStyle": "space",
    "quoteStyle": "single"
  },
  "json": {
    "trailingCommas": "never"
  },
  "markdown": {},
  "markup": {},
  "yaml": {
    "quotes": "preferSingle",
    "formatComments": true
  },
  "exec": {
    "commands": [
      {
        "command": "stylua --allow-hidden --respect-ignores --stdin-filepath {{file_path}} -",
        "exts": [".lua"]
      },
      {
        "command": "taplo format -",
        "exts": [".toml"]
      },
      {
        "command": "shfmt -i 2 -ci -bn -s -",
        "exts": [".sh", ".bash", ".zsh"]
      },
      {
        "command": "shfmt -i 2 -ci -bn -s -",
        "fileNames": [
          "bic",
          "bip",
          "command-history-preview",
          "figprev",
          "ghprs",
          "git_better_branch",
          "nvims",
          "pingf",
          "pplay",
          "tmux-fork-repo",
          "tmux-new-session",
          "v",
          "wait_for_port"
        ]
      }
    ]
  },
  "excludes": [
    "**/*-lock.yaml",
    "**/*lock.json",
    "CHANGELOG.md",
    "config/yazi/plugins/smart-enter.yazi/**",
    "config/leader-key/config.json",
    "gitleaks-report.json",
    "config/claude/statsig/**/*.*",
    "config/claude/projects/**/*.*",
    "config/claude/todos/**/*.*"
  ],
  "plugins": [
    "https://plugins.dprint.dev/biome-0.12.0.wasm",
    "https://plugins.dprint.dev/json-0.21.1.wasm",
    "https://plugins.dprint.dev/markdown-0.21.1.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.26.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/exec-0.6.0.json@a054130d458f124f9b5c91484833828950723a5af3f8ff2bd1523bd47b83b364"
  ]
}
