#!/usr/bin/env zsh

set -euo pipefail

use_lnr_quick=${TMUX_WORKMUX_LNR_QUICK:-}
input_placeholder="Worktree name..."

while (($#)); do
  case "$1" in
    --no-ticket)
      use_lnr_quick=""
      ;;
    *)
      print -r -- "Unknown option: $1" >&2
      exit 1
      ;;
  esac
  shift
done

if [[ -n "$use_lnr_quick" ]] && ! mise x -- gum confirm "Create a ticket for this worktree?"; then
  use_lnr_quick=""
fi

if [[ -n "$use_lnr_quick" ]]; then
  input_placeholder="Ticket title..."
fi

worktree_input=$(mise x -- gum input --placeholder="$input_placeholder")

if [[ -z "$worktree_input" ]]; then
  exit 0
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  mise x -- gum style --foreground="red" "Not in a git repository"
  exit 1
fi

base_branch=$(mise x -- tv workmux-base-branch --hide-status-bar || true)

if [[ -z "$base_branch" ]]; then
  exit 0
fi

worktree_name=$worktree_input

if [[ -n "$use_lnr_quick" ]]; then
  worktree_name=$(mise x -- lnr quick "$worktree_input")
  worktree_name=${worktree_name//$'\r'/}

  if [[ -z "$worktree_name" ]]; then
    mise x -- gum style --foreground="red" "lnr quick did not return a branch name"
    exit 1
  fi
fi

worktree_name=${worktree_name//[[:space:]]/-}
prompt_file=$(mktemp -t workmux-add-prompt)
trap 'rm -f "$prompt_file"' EXIT

mise x -- nvim "+startinsert" "+set ft=markdown" "$prompt_file"

prompt_text=$(<"$prompt_file")

if [[ -z "${prompt_text//[[:space:]]/}" ]]; then
  exit 0
fi

mise x -- workmux add "$worktree_name" --base "$base_branch" --prompt "$prompt_text" --background
