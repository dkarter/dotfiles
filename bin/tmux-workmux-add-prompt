#!/usr/bin/env bash

set -euo pipefail

worktree_name=$(mise x -- gum input --placeholder="Worktree name...")

if [[ -z "$worktree_name" ]]; then
  exit 0
fi

prompt_text=$(mise x -- gum write --placeholder="Prompt for this worktree...")

if [[ -z "$prompt_text" ]]; then
  exit 0
fi

mise x -- workmux add "$worktree_name" --prompt "$prompt_text" --background
