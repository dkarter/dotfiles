#!/usr/bin/env zsh
set -euo pipefail

script_dir=$(cd -- "$(dirname "$0")" && pwd)
command_parts=("${script_dir}/tmux-workmux-add-prompt" "$@")
quoted_parts=()

for part in "${command_parts[@]}"; do
  quoted_parts+=("${(q)part}")
done

command="${(j: :)quoted_parts}"

extended_keys=$(tmux show-options -gqv extended-keys)

restore_extended_keys() {
  tmux set-option -gq extended-keys "$extended_keys"
}

trap restore_extended_keys EXIT
trap 'exit 130' INT TERM

# tmux popups can leak CSI-u newlines into Nvim paste when extended keys are on.
tmux set-option -gq extended-keys off
tmux display-popup -E -w 60% -h 70% "$command"
